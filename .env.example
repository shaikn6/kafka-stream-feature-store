# PostgreSQL credentials (required)
POSTGRES_USER=featurestore
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=featurestore
DATABASE_URL=postgresql://featurestore:change-me-strong-password@localhost:5432/featurestore

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_FEATURE_TOPIC=features.raw
KAFKA_CONSUMER_GROUP=feature-store-consumer

# App
MONITOR_INTERVAL_SECONDS=15
